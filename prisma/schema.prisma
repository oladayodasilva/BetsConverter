generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())

  calculations Calculation[]
  aiChats      AiChat[]
}

model Calculation {
  id        String   @id @default(cuid())
  userId    String
  type      String
  input     Json
  result    Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AiChat {
  id        String   @id @default(cuid())
  userId    String?
  prompt    String
  response  String
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}